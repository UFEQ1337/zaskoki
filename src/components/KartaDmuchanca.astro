---
import { Image, getImage } from 'astro:assets';
import type { Dmuchaniec } from '../data/dmuchance';
import { firma } from '../data/firma';

interface Props {
  dmuchaniec: Dmuchaniec;
}
const { dmuchaniec: d } = Astro.props;

// Większa wersja zdjęcia do dymka ze szczegółami.
const duze = await getImage({ src: d.zdjecie.src, width: 900, format: 'webp' });
---

<article class="karta" style={`--akcent:${d.akcent}`}>
  <div class="karta__media">
    <Image
      src={d.zdjecie.src}
      alt={d.zdjecie.alt}
      widths={[320, 520, 760]}
      sizes="(max-width: 700px) 90vw, 360px"
      loading="lazy"
      class="karta__img"
    />

    <div class="karta__overlay">
      <button
        type="button"
        class="karta__details"
        data-szczegoly
        data-nazwa={d.nazwa}
        data-motyw={d.motyw}
        data-opis={d.opis}
        data-cena4h={d.cena4h}
        data-cenadzien={d.cenaDzien}
        data-img={duze.src}
        data-alt={d.zdjecie.alt}
        data-params={JSON.stringify(d.parametry)}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /><line x1="11" y1="8" x2="11" y2="8.01" /><line x1="11" y1="11" x2="11" y2="14" /></svg>
        Szczegóły
      </button>
    </div>
  </div>

  <div class="karta__body">
    <h3 class="karta__title sr-only">{d.nazwa}</h3>
    <div class="karta__theme">{d.motyw}</div>

    <div class="karta__certs" aria-label="Certyfikaty i dokumenty">
      {firma.certyfikaty.map((c) => <span class="karta__cert">{c}</span>)}
    </div>

    <div class="karta__pills">
      <span class="pill">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1FA9E0" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /></svg>
        {d.wymiary}
      </span>
      <span class="pill">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2BB89A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" /></svg>
        {d.liczbaDzieci}
      </span>
      <span class="pill">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#FF7A1A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
        {d.wiek}
      </span>
    </div>

    <div class="karta__footer">
      <div class="karta__prices">
        <div class="karta__price karta__price--hot">
          <span class="karta__price-label">4 h</span>
          <span class="karta__price-val">{d.cena4h}</span>
        </div>
        <div class="karta__price">
          <span class="karta__price-label">Cały dzień</span>
          <span class="karta__price-val">{d.cenaDzien}</span>
        </div>
      </div>
      <a href="#kontakt" class="btn btn--yellow karta__order">
        Zamów
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#2A2342" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</article>

<style>
  .karta {
    background: #fff;
    border-radius: 26px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(42, 35, 66, 0.05);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
  }
  .karta:hover {
    transform: translateY(-8px);
    box-shadow: 0 26px 50px rgba(255, 122, 26, 0.2);
  }

  .karta__media {
    position: relative;
    aspect-ratio: 4 / 3;
    /* Bannery mają własne, jasne tło — „contain" pokazuje cały baner (też pionowy dart). */
    background: #fff;
  }
  .karta__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Nakładka z przyciskiem „Szczegóły" (hover / focus) */
  .karta__overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, rgba(20, 15, 32, 0) 35%, rgba(20, 15, 32, 0.42) 100%);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .karta:hover .karta__overlay,
  .karta__overlay:focus-within {
    opacity: 1;
  }
  .karta__details {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
    background: #fff;
    color: var(--c-ink);
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 15px;
    padding: 12px 20px;
    border-radius: 999px;
    box-shadow: 0 12px 26px rgba(0, 0, 0, 0.25);
    transform: translateY(8px);
    transition: transform 0.25s ease;
  }
  .karta:hover .karta__details,
  .karta__overlay:focus-within .karta__details {
    transform: translateY(0);
  }
  .karta__details svg { color: var(--c-orange); }

  .karta__body {
    padding: 18px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .karta__theme {
    font-weight: 800;
    font-size: 14px;
    margin-bottom: 12px;
    color: var(--akcent, var(--c-orange));
  }

  /* Certyfikaty pod zdjęciem (nie zasłaniają tekstu na bannerze) */
  .karta__certs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }
  .karta__cert {
    background: var(--c-mint-soft);
    color: var(--c-blue-strong);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.2px;
    padding: 4px 9px;
    border-radius: 7px;
  }

  .karta__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }
  .karta__footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .karta__prices {
    display: flex;
    gap: 10px;
  }
  .karta__price {
    display: flex;
    flex-direction: column;
    flex: 1;
    background: var(--c-cream);
    border: 1px solid transparent;
    border-radius: 14px;
    padding: 9px 13px;
  }
  .karta__price-label {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--c-gray);
  }
  .karta__price-val {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 21px;
    color: var(--c-ink);
    line-height: 1.1;
  }
  /* Wyróżniona, tańsza opcja (4 h) */
  .karta__price--hot {
    background: var(--c-peach);
    border-color: rgba(196, 77, 10, 0.28);
    box-shadow: 0 8px 18px rgba(196, 77, 10, 0.12);
  }
  .karta__price--hot .karta__price-val {
    color: var(--c-orange);
    font-size: 25px;
  }
  .karta__order {
    width: 100%;
  }

  /* Dotyk (brak hovera): nakładka i przycisk zawsze widoczne */
  @media (hover: none) {
    .karta__overlay {
      opacity: 1;
      background: linear-gradient(180deg, rgba(20, 15, 32, 0) 60%, rgba(20, 15, 32, 0.3) 100%);
      align-items: flex-end;
      justify-content: center;
      padding-bottom: 12px;
    }
    .karta__details {
      transform: none;
      font-size: 13px;
      padding: 9px 14px;
    }
  }
</style>
