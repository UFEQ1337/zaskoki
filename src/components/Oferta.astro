---
import { dmuchance } from '../data/dmuchance';
import { firma } from '../data/firma';
import KartaDmuchanca from './KartaDmuchanca.astro';
---

<section id="oferta" class="section oferta">
  <div class="container">
    <div class="oferta__head" data-reveal>
      <span class="eyebrow">Oferta</span>
      <h2 class="section-title">Nasze atrakcje</h2>
      <p class="oferta__sub">Kliknij zdjęcie, aby zobaczyć galerię.</p>
    </div>

    <div class="oferta__promo" data-reveal>
      <div class="oferta__promo-box">
        <span class="oferta__promo-badge">{firma.rabat.wartosc}</span>
        <span class="oferta__promo-text">{firma.rabat.haslo}</span>
      </div>
    </div>

    <div class="oferta__grid">
      {dmuchance.map((d) => <KartaDmuchanca dmuchaniec={d} />)}
    </div>

    <p class="oferta__note" data-reveal>
      Ceny od {firma.cenaOd} do {firma.cenaDo} zł / dzień. Dokładną wycenę i dostępność
      potwierdzamy telefonicznie.
    </p>
  </div>
</section>

<style>
  .oferta { background: var(--c-cream); }
  .oferta__head {
    text-align: center;
    margin-bottom: clamp(28px, 4vw, 44px);
  }
  .oferta__head .section-title { margin-bottom: 8px; }
  .oferta__sub {
    font-size: clamp(16px, 2.2vw, 18px);
    color: var(--c-gray);
    margin: 0;
  }

  .oferta__promo {
    display: flex;
    justify-content: center;
    margin-bottom: clamp(26px, 4vw, 40px);
  }
  .oferta__promo-box {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #fff;
    border: 2px dashed var(--c-yellow);
    padding: 14px 22px;
    border-radius: 999px;
  }
  .oferta__promo-badge {
    background: var(--c-orange);
    color: #fff;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 16px;
    padding: 6px 13px;
    border-radius: 999px;
  }
  .oferta__promo-text {
    font-weight: 800;
    font-size: clamp(14px, 2.4vw, 16px);
    color: var(--c-ink);
  }

  .oferta__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(265px, 1fr));
    gap: clamp(20px, 3vw, 26px);
  }

  .oferta__note {
    text-align: center;
    font-size: 14.5px;
    color: var(--c-gray);
    margin: clamp(26px, 4vw, 38px) auto 0;
    max-width: 560px;
  }
</style>

<!-- Style GLightboxa — klasy generowane dynamicznie, więc globalne. -->
<style is:global>
  .glightbox-clean .gnext svg,
  .glightbox-clean .gprev svg,
  .glightbox-clean .gclose svg {
    width: 22px;
    height: 22px;
  }

  /* Mobile: GLightbox domyślnie chowa strzałki (zostaje sam swipe). Pokazujemy je jako pewny fallback. */
  @media (max-width: 768px) {
    .glightbox-container .gprev,
    .glightbox-container .gnext {
      position: fixed !important;
      top: 50% !important;
      bottom: auto !important;
      transform: translateY(-50%) !important;
      width: 46px !important;
      height: 46px !important;
      background: rgba(20, 15, 32, 0.55) !important;
      border-radius: 50% !important;
      z-index: 100000 !important;
    }
    .glightbox-container .gprev {
      left: 12px !important;
      right: auto !important;
    }
    .glightbox-container .gnext {
      right: 12px !important;
      left: auto !important;
    }
  }
</style>

<script>
  // GLightbox ładowany leniwie — dopiero przy sekcji „Oferta".
  // Karuzela kart to natywny scroll-snap
  import 'glightbox/dist/css/glightbox.min.css';

  let booted = false;

  // Lekki kontroler natywnej karuzeli (scroll-snap): kropki + strzałki.
  function initCarousel(el: HTMLElement) {
    if (el.dataset.carouselBound === '1') return;
    el.dataset.carouselBound = '1';

    const track = el.querySelector<HTMLElement>('[data-track]');
    if (!track) return;
    const slides = Array.from(track.querySelectorAll<HTMLElement>('.karta__slide'));
    const dots = Array.from(el.querySelectorAll<HTMLElement>('[data-dot]'));
    if (slides.length < 2) return;

    let current = 0;
    const setActive = (i: number) => {
      if (i === current) return;
      current = i;
      dots.forEach((d, idx) => d.classList.toggle('is-active', idx === i));
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting && e.intersectionRatio >= 0.6) {
              setActive(slides.indexOf(e.target as HTMLElement));
            }
          }
        },
        { root: track, threshold: [0.6] }
      );
      slides.forEach((s) => io.observe(s));
    } else {
      track.addEventListener('scroll', () => {
        setActive(Math.round(track.scrollLeft / track.clientWidth));
      }, { passive: true });
    }

    const go = (dir: number) => {
      const next = (current + dir + slides.length) % slides.length;
      track.scrollTo({ left: next * track.clientWidth, behavior: 'smooth' });
    };
    el.querySelector<HTMLElement>('[data-prev]')?.addEventListener('click', () => go(-1));
    el.querySelector<HTMLElement>('[data-next]')?.addEventListener('click', () => go(1));
  }

  async function bootOferta() {
    if (booted) return;
    booted = true;

    document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);

    const { default: GLightbox } = await import('glightbox');
    GLightbox({
      selector: '.glightbox',
      loop: true,
      touchNavigation: true,
      zoomable: false, // bez zoomu zdjęcia => płynne przesuwanie palcem między zdjęciami na mobile
      openEffect: 'fade',
      closeEffect: 'fade',
    });
  }

  function watchOferta() {
    const section = document.getElementById('oferta');
    if (!section) return;
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries, obs) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              obs.disconnect();
              bootOferta();
            }
          }
        },
        { rootMargin: '300px 0px' }
      );
      io.observe(section);
    } else {
      bootOferta();
    }
  }

  watchOferta();
  document.addEventListener('astro:page-load', watchOferta);
</script>
