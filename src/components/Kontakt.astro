---
import { firma } from '../data/firma';

const obszar = firma.miejscowosci.join(', ');
---

<section id="kontakt" class="section kontakt">
  <div class="container kontakt__inner" data-reveal>
    <span class="eyebrow">Kontakt</span>
    <h2 class="section-title">Zarezerwuj termin</h2>
    <p class="kontakt__lead">
      Zadzwoń — sprawdzimy dostępność i ustalimy szczegóły dostawy. Najszybciej złapiesz nas
      telefonicznie.
    </p>

    <a href={`tel:${firma.telefon.e164}`} class="kontakt__phone">
      <span class="kontakt__phone-ic" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
      </span>
      <span>
        <span class="kontakt__phone-label">Zadzwoń teraz</span>
        <span class="kontakt__phone-num">{firma.telefon.display}</span>
      </span>
    </a>

    {
      firma.email && (
        <a href={`mailto:${firma.email}`} class="kontakt__email">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-10 6L2 7" /></svg>
          {firma.email}
        </a>
      )
    }

    <p class="kontakt__area">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1FA9E0" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
      <span>Obszar działania: {obszar} i okolice.</span>
    </p>
  </div>
</section>

<style>
  .kontakt { background: transparent; }
  .kontakt__inner {
    max-width: 640px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .kontakt__lead {
    font-size: 17px;
    line-height: 1.6;
    color: var(--c-gray);
    margin: 14px 0 28px;
    max-width: 460px;
  }

  .kontakt__phone {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    background: linear-gradient(135deg, var(--c-orange), var(--c-yellow));
    padding: 20px 30px;
    border-radius: 22px;
    box-shadow: 0 18px 38px rgba(255, 122, 26, 0.3);
    transition: transform 0.18s ease;
  }
  .kontakt__phone:hover { transform: translateY(-2px); }
  .kontakt__phone-ic {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .kontakt__phone > span:last-child { text-align: left; }
  .kontakt__phone-label {
    display: block;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 700;
    font-size: 14px;
  }
  .kontakt__phone-num {
    display: block;
    color: #fff;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 28px;
    line-height: 1.1;
  }

  .kontakt__email {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: 22px;
    color: var(--c-blue-strong);
    font-weight: 800;
    font-size: 16px;
    text-decoration: none;
  }
  .kontakt__email:hover {
    text-decoration: underline;
  }

  .kontakt__area {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    justify-content: center;
    color: var(--c-gray);
    font-size: 15px;
    font-weight: 700;
    margin: 26px 0 0;
    max-width: 520px;
  }
  .kontakt__area svg { flex-shrink: 0; margin-top: 1px; }
</style>
